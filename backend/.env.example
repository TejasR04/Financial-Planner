ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://meridian:meridian@localhost:5432/meridian

JWT_SECRET_KEY=replace-with-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in every environment that stores linked Plaid accounts. Rotating
# this key makes existing stored access tokens undecryptable, so back it up
# somewhere safe (a secrets manager, not source control) once you're past sandbox.
PLAID_TOKEN_ENCRYPTION_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

CORS_ALLOW_ORIGINS=["http://localhost:3000"]
